{
    "name": "lattice/openapi",
    "description": "OpenAPI 3.1 specification generator for LatticePHP",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "framework",
        "openapi",
        "swagger",
        "api-docs",
        "lattice"
    ],
    "homepage": "https://github.com/LatticePHP/framework",
    "support": {
        "issues": "https://github.com/LatticePHP/framework/issues",
        "source": "https://github.com/LatticePHP/openapi"
    },
    "require": {
        "php": "^8.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\OpenApi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\OpenApi\\Tests\\": "tests/"
        }
    }
}
